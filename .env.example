# Solana Trading Bot Environment

# Network: mainnet, devnet, testnet
NETWORK=mainnet

# RPC endpoint (optional - uses defaults if not set)
# RPC_URL=https://your-custom-rpc.com

# Commitment level: processed, confirmed, finalized
COMMITMENT=confirmed

# Paper trading mode (true/false)
PAPER_TRADING=true

# Strategy configs
MIN_PROFIT_PERCENT=0.5
MAX_SLIPPAGE_BPS=50
TRADE_SIZE_SOL=0.1

# MEV (Jito)
JITO_ENABLED=false
JITO_BLOCK_ENGINE_URL=https://mainnet.block-engine.jito.wtf/api/v1
